<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Reviews | SMJ Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">

    <div class="d-flex flex-column flex-lg-row" id="wrapper">
        
        <%- include('partials/admin-sidebar') %>

        <div id="page-content-wrapper" class="w-100 overflow-hidden bg-light">
            
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 px-4 shadow-sm mb-4">
                <h4 class="mb-0 fw-bold"><a href="/admin" class="text-dark text-decoration-none"><i class="fas fa-arrow-left me-3"></i></a> Customer Reviews</h4>
            </nav>

            <div class="container-fluid px-2 px-lg-4 pb-5">
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0 text-muted">All Product Reviews</h5>
                </div>
                
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="min-width: 800px;">
                            <thead class="bg-light text-muted small text-uppercase">
                                <tr>
                                    <th class="py-3 px-4">Product</th>
                                    <th class="py-3">Customer</th>
                                    <th class="py-3">Rating & Comment</th>
                                    <th class="py-3 text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% let hasReviews = false; %>
                                <% if (products && products.length > 0) { %>
                                    <% products.forEach(product => { %>
                                        <% if(product.reviews && product.reviews.length > 0) { %>
                                            <% hasReviews = true; %>
                                            <% product.reviews.reverse().forEach(review => { %>
                                                <tr>
                                                    <td class="px-4 py-3" style="max-width: 250px;">
                                                        <div class="d-flex align-items-center">
                                                            <img src="<%= product.imagePath %>" class="rounded shadow-sm me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                            <div>
                                                                <span class="fw-bold text-dark d-block text-truncate" style="max-width: 150px;"><%= product.name %></span>
                                                                <span class="badge bg-secondary"><%= product.category %></span>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    
                                                    <td class="py-3">
                                                        <span class="fw-bold d-block text-dark"><i class="fas fa-user-circle text-muted me-1"></i> <%= review.userName %></span>
                                                        <span class="small text-muted"><i class="far fa-calendar-alt me-1"></i> <%= new Date(review.date).toLocaleDateString('en-IN') %></span>
                                                    </td>

                                                    <td class="py-3" style="max-width: 300px;">
                                                        <div class="text-warning mb-1" style="font-size: 0.85rem;">
                                                            <% for(let i=1; i<=5; i++) { %>
                                                                <i class="<%= i <= (review.rating || 5) ? 'fas' : 'far' %> fa-star"></i>
                                                            <% } %>
                                                        </div>
                                                        <p class="mb-0 text-muted small text-wrap"><%= review.comment %></p>
                                                    </td>

                                                    <td class="py-3 text-center">
                                                        <form action="/admin/delete-review/<%= product._id %>/<%= review._id %>" method="POST" onsubmit="return confirm('Delete this review permanently?');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 35px; height: 35px;" title="Delete Review">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } %>
                                    <% }) %>
                                <% } %>

                                <% if (!hasReviews) { %>
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="fas fa-comment-slash fs-1 mb-3 opacity-25"></i>
                                            <h5>No Reviews Yet</h5>
                                            <p class="small">When customers leave a review, it will appear here.</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>