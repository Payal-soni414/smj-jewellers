<%- include('partials/header') %>

<div class="container py-5 mt-4 mt-md-5">
    <div class="row justify-content-center">
        <div class="col-11 col-sm-8 col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 p-md-5 mt-3 mt-md-5">
                <div class="text-center mb-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px;">
                        <i class="fas fa-user-lock text-warning fa-2x" style="color: #d4af37 !important;"></i>
                    </div>
                    <h3 class="fw-bold fs-4 fs-md-3" style="color: #2c3e50;">Welcome Back</h3>
                    <p class="text-muted small px-2">Login to your Shree Mahalakshmi account</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger border-0 small py-2 d-flex align-items-center rounded-3 shadow-sm" role="alert" style="background-color: #f8d7da; color: #842029;">
                        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
                    </div>
                <% } %>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert alert-success border-0 small py-2 d-flex align-items-center rounded-3 shadow-sm" role="alert">
                        <i class="fas fa-check-circle me-2"></i> <%= success %>
                    </div>
                <% } %>

                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Email Address</label>
                        <input type="email" name="email" class="form-control bg-light border-0 py-2 py-md-3 shadow-sm rounded-3" placeholder="Enter your email" required>
                    </div>
                    
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label small fw-bold text-muted mb-0">Password</label>
                        </div>
                        
                        <div class="input-group shadow-sm rounded-3 overflow-hidden bg-light border border-light focus-ring-gold">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                            <input type="password" id="loginPassword" name="password" class="form-control bg-light border-0 py-2 py-md-3 ps-1 shadow-none" placeholder="Enter your password" required>
                            <button class="btn bg-light border-0 text-muted px-3 shadow-none" type="button" onclick="togglePassword('loginPassword', 'eyeIconLogin')">
                                <i class="far fa-eye" id="eyeIconLogin"></i>
                            </button>
                        </div>
                        <div class="text-end mt-2">
                            <a href="/forgot-password" class="text-decoration-none small fw-bold hover-warning" style="color: #d4af37; transition: 0.3s;">Forgot Password?</a>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold py-2 py-md-3 mb-3 shadow-sm custom-btn" style="background-color: #d4af37; border: none; transition: 0.3s;">
                        Login Securely <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                </form>
                
                <div class="text-center mt-2">
                    <p class="text-muted small mb-0">Don't have an account? 
                        <a href="/signup" class="text-decoration-none fw-bold hover-dark" style="color: #2c3e50; transition: 0.3s;">Create Account</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    input::-ms-reveal,
    input::-ms-clear {
        display: none !important;
    }
    .form-control:focus { outline: 1px solid #d4af37; background-color: #fff !important; }
    .focus-ring-gold:focus-within { outline: 1px solid #d4af37; background-color: #fff !important; }
    .focus-ring-gold:focus-within input, .focus-ring-gold:focus-within span, .focus-ring-gold:focus-within button { background-color: #fff !important; }
    .custom-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(212, 175, 55, 0.4) !important;
        background-color: #b8962e !important;
    }
    .hover-warning:hover { color: #b8962e !important; }
    .hover-dark:hover { color: #d4af37 !important; }
</style>

<script>
    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = "password";
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }
</script>

<%- include('partials/footer') %>