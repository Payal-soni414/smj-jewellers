<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Business Analytics | SMJ Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light">

    <div class="d-flex flex-column flex-lg-row" id="wrapper">
        
        <%- include('partials/admin-sidebar') %>

        <div id="page-content-wrapper" class="w-100 overflow-hidden bg-light">
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 px-4 shadow-sm mb-4">
                <h4 class="mb-0 fw-bold"><a href="/admin" class="text-dark text-decoration-none"><i class="fas fa-arrow-left me-3"></i></a> Business Analytics</h4>
            </nav>

            <div class="container-fluid px-4">
                
                <div class="row g-4 mb-4">
                    <div class="col-sm-6 col-xl-3">
                        <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100" style="background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);">
                            <h6 class="text-white fw-bold mb-2">Total Revenue</h6>
                            <h3 class="fw-bold text-white mb-0">₹ <%= typeof totalRevenue !== 'undefined' ? Math.round(totalRevenue).toLocaleString('en-IN') : '0' %></h3>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white border-start border-4 border-primary h-100">
                            <h6 class="text-muted fw-bold mb-2">Total Orders</h6>
                            <h3 class="fw-bold text-dark mb-0"><%= typeof totalOrders !== 'undefined' ? totalOrders : '0' %></h3>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white border-start border-4 border-success h-100">
                            <h6 class="text-muted fw-bold mb-2">Total Products</h6>
                            <h3 class="fw-bold text-dark mb-0"><%= typeof totalProducts !== 'undefined' ? totalProducts : '0' %></h3>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white border-start border-4 border-info h-100">
                            <h6 class="text-muted fw-bold mb-2">Registered Users</h6>
                            <h3 class="fw-bold text-dark mb-0"><%= typeof totalUsers !== 'undefined' ? totalUsers : '0' %></h3>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 overflow-x-auto">
                            <h5 class="fw-bold text-dark mb-4">Top 5 Best Selling Products</h5>
                            <div style="min-width: 400px;">
                                <canvas id="salesChart" height="100"></canvas>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                            <h5 class="fw-bold text-danger mb-4"><i class="fas fa-exclamation-triangle me-2"></i> Out of Stock Alerts</h5>
                            <% if(typeof outOfStockItems !== 'undefined' && outOfStockItems.length > 0) { %>
                                <ul class="list-group list-group-flush" style="max-height: 250px; overflow-y: auto;">
                                    <% outOfStockItems.forEach(item => { %>
                                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                            <div class="d-flex align-items-center">
                                                <img src="<%= item.imagePath %>" class="rounded me-2 shadow-sm" style="width: 40px; height: 40px; object-fit: cover;">
                                                <span class="small fw-bold text-truncate" style="max-width: 130px;"><%= item.name %></span>
                                            </div>
                                            <span class="badge bg-danger rounded-pill">0 Stock</span>
                                        </li>
                                    <% }) %>
                                </ul>
                                <a href="/admin/manage-products" class="btn btn-sm btn-outline-danger w-100 mt-auto rounded-pill fw-bold">Restock Items</a>
                            <% } else { %>
                                <div class="text-center py-4 mt-4">
                                    <i class="fas fa-check-circle text-success fa-3x mb-2"></i>
                                    <p class="text-muted small fw-bold">All products are well stocked!</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            let pNamesRaw = '<%- typeof topProductNames !== "undefined" ? topProductNames : "[]" %>';
            let pSalesRaw = '<%- typeof topProductQuantities !== "undefined" ? topProductQuantities : "[]" %>';

            let pNames = JSON.parse(pNamesRaw);
            let pSales = JSON.parse(pSalesRaw);

            if(pNames.length === 0) { pNames = ["No Sales"]; pSales = [0]; }

            const ctx = document.getElementById('salesChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: pNames,
                    datasets: [{
                        label: 'Units Sold', data: pSales,
                        backgroundColor: ['rgba(212, 175, 55, 0.8)', 'rgba(44, 62, 80, 0.8)', 'rgba(231, 76, 60, 0.8)', 'rgba(46, 204, 113, 0.8)', 'rgba(155, 89, 182, 0.8)'],
                        borderRadius: 6, borderWidth: 0
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }, plugins: { legend: { display: false } } }
            });
        });
    </script>
</body>
</html>