<%- include('partials/header') %>

<div class="container py-5 mt-4 mt-md-5">
    <div class="row justify-content-center">
        <div class="col-11 col-sm-10 col-md-8 col-lg-6 col-xl-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 p-md-5 mt-3 mt-md-0">
                <div class="text-center mb-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 70px; height: 70px;">
                        <i class="fas fa-user-plus text-warning fs-3" style="color: #d4af37 !important;"></i>
                    </div>
                    <h3 class="fw-bold fs-4 fs-md-3" style="color: #2c3e50;">Create Account</h3>
                    <p class="text-muted small px-2">Join Shree Mahalakshmi Jewellers Family</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger border-0 small py-2 d-flex align-items-center rounded-3 shadow-sm" role="alert" style="background-color: #f8d7da; color: #842029;">
                        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
                    </div>
                <% } %>

                <form action="/signup" method="POST">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Full Name</label>
                        <input type="text" name="name" class="form-control bg-light border-0 py-2 py-md-3 shadow-sm rounded-3" placeholder="e.g. Payal Soni" required>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 mb-1">
                            <label class="form-label small fw-bold text-muted">Mobile Number</label>
                            <input type="tel" name="mobile" class="form-control bg-light border-0 py-2 py-md-3 shadow-sm rounded-3" placeholder="10-digit number" pattern="[0-9]{10}" required>
                        </div>
                        <div class="col-12 col-md-6 mb-1">
                            <label class="form-label small fw-bold text-muted">Email Address</label>
                            <input type="email" name="email" class="form-control bg-light border-0 py-2 py-md-3 shadow-sm rounded-3" placeholder="Email ID" required>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-12 col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Password</label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden bg-light border border-light focus-ring-gold">
                                <span class="input-group-text bg-light border-0 px-2"><i class="fas fa-lock text-muted small"></i></span>
                                <input type="password" id="signupPassword" name="password" class="form-control bg-light border-0 py-2 py-md-3 ps-1 shadow-none" placeholder="Create" required minlength="6">
                                <button class="btn bg-light border-0 text-muted px-2 shadow-none" type="button" onclick="togglePassword('signupPassword', 'eyeIconSignup1')">
                                    <i class="far fa-eye" id="eyeIconSignup1"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 mb-4">
                            <label class="form-label small fw-bold text-muted">Confirm Password</label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden bg-light border border-light focus-ring-gold">
                                <span class="input-group-text bg-light border-0 px-2"><i class="fas fa-check-circle text-muted small"></i></span>
                                <input type="password" id="signupConfirmPassword" name="confirmPassword" class="form-control bg-light border-0 py-2 py-md-3 ps-1 shadow-none" placeholder="Re-enter" required minlength="6">
                                <button class="btn bg-light border-0 text-muted px-2 shadow-none" type="button" onclick="togglePassword('signupConfirmPassword', 'eyeIconSignup2')">
                                    <i class="far fa-eye" id="eyeIconSignup2"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold py-2 py-md-3 mb-3 shadow-sm custom-signup-btn" style="background-color: #d4af37; border: none; transition: 0.3s;">
                        Create Account <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                </form>
                
                <div class="text-center mt-2">
                    <p class="text-muted small mb-0">Already have an account? 
                        <a href="/login" class="text-decoration-none fw-bold hover-dark" style="color: #2c3e50; transition: 0.3s;">Login Here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Browser default cleaning */
    input::-ms-reveal, input::-ms-clear { display: none !important; }

    /* Focus effects */
    .form-control:focus { outline: 1px solid #d4af37; background-color: #fff !important; }
    .focus-ring-gold:focus-within { outline: 1px solid #d4af37; background-color: #fff !important; }
    .focus-ring-gold:focus-within input, .focus-ring-gold:focus-within span, .focus-ring-gold:focus-within button { background-color: #fff !important; }
    
    /* Animation & Hover */
    .custom-signup-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(212, 175, 55, 0.4) !important;
        background-color: #b8962e !important;
    }
    .hover-dark:hover { color: #d4af37 !important; }
</style>

<script>
    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = "password";
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>

<%- include('partials/footer') %>