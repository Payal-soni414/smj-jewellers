<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Subscribers | SMJ Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">

    <div class="d-flex flex-column flex-lg-row" id="wrapper">
        
        <%- include('partials/admin-sidebar') %>

        <div id="page-content-wrapper" class="w-100 overflow-hidden bg-light">
            
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 px-4 shadow-sm mb-4">
                <h4 class="mb-0 fw-bold"><a href="/admin" class="text-dark text-decoration-none"><i class="fas fa-arrow-left me-3"></i></a> Newsletter Subscribers</h4>
            </nav>

            <div class="container-fluid px-2 px-lg-4 pb-5">
                <div class="row">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0 text-muted">All Subscribers</h5>
                        </div>
                        
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden p-4">
                            <% if (subscribers && subscribers.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light text-muted small text-uppercase">
                                            <tr>
                                                <th scope="col" class="py-3 px-3">#</th>
                                                <th scope="col" class="py-3">Email Address</th>
                                                <th scope="col" class="py-3">Subscribed On</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% subscribers.forEach((sub, index) => { %>
                                                <tr>
                                                    <td class="px-3 fw-bold text-muted"><%= index + 1 %></td>
                                                    <td class="fw-bold text-primary"><i class="fas fa-envelope me-2 text-muted"></i><%= sub.email %></td>
                                                    <td class="text-muted"><i class="far fa-calendar-alt me-2"></i><%= new Date(sub.subscribedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <i class="fas fa-envelope-open-text fa-4x text-muted mb-3 opacity-25"></i>
                                    <h4 class="fw-bold text-muted">No Subscribers Yet</h4>
                                    <p class="text-muted small">When customers subscribe, their emails will appear here.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>