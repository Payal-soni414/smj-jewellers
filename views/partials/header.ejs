<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shree Mahalakshmi Jewellers</title>
    <link rel="icon" type="image/png" href="/images/logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .nav-link:hover { color: #d4af37 !important; }
        input[type="search"]::-webkit-search-decoration,
        input[type="search"]::-webkit-search-cancel-button,
        input[type="search"]::-webkit-search-results-button,
        input[type="search"]::-webkit-search-results-decoration {
            display: none;
        }

        /* Mobile Adjustments */
        @media (max-width: 991px) {
            .rate-text { font-size: 0.75rem; text-align: center; width: 100%; white-space: nowrap; }
            .top-bar { overflow: hidden; }
        }
    </style>
</head>
<body>

    <div class="top-bar shadow-sm" style="background-color: #2c3e50; color: #d4af37; padding: 6px 0; font-size: 0.85rem;">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-none d-lg-block">
                <i class="fas fa-phone-alt me-2"></i> +91 9549589500
            </div>
            
            <div class="rate-text mx-auto mx-lg-0">
                Live Rate: 22K Gold - ₹ <%= typeof liveRate !== 'undefined' && liveRate.goldRate22K ? Math.round(liveRate.goldRate22K).toLocaleString('en-IN') : 'Updating...' %>/gm | 
                Silver - ₹ <%= typeof liveRate !== 'undefined' && liveRate.silverRate ? Math.round(liveRate.silverRate).toLocaleString('en-IN') : 'Updating...' %>/kg
            </div>
            
            <div class="d-none d-lg-block fw-bold text-white">
                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="text-warning text-decoration-none"><i class="fas fa-crown me-1"></i> Admin Panel</a>
                <% } else { %>
                    <span style="color: #d4af37;"><i class="fas fa-gem me-1"></i> Welcome to SMJ</span>
                <% } %>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg sticky-top py-2 bg-white shadow-sm">
        <div class="container">
            
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/logo.png" alt="SMJ Logo" style="height: 50px; width: auto; object-fit: contain;">
            </a>

            <div class="d-flex align-items-center gap-3 d-lg-none">
                <a href="/wishlist" class="text-dark position-relative">
                    <i class="far fa-heart fs-5"></i>
                </a>
                
                <a href="/cart" class="text-dark position-relative">
                    <i class="fas fa-shopping-bag fs-5"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                        <%= typeof cartItemCount !== 'undefined' ? cartItemCount : 0 %>
                    </span>
                </a>
                <button class="navbar-toggler border-0 p-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon" style="width: 24px; height: 24px;"></span>
                </button>
            </div>

            <div class="collapse navbar-collapse" id="mainNav">
                
                <div class="d-lg-none px-2 mt-3 mb-2">
                    <form action="/search" method="GET" class="position-relative w-100">
                        <input class="form-control rounded-pill border-0 bg-light py-2 shadow-sm" type="search" name="q" placeholder="Search jewellery..." required style="padding-right: 45px;">
                        <button class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-muted border-0 shadow-none" type="submit" style="text-decoration:none;"><i class="fas fa-search"></i></button>
                    </form>
                </div>

                <ul class="navbar-nav me-auto ms-lg-4 mb-2 mb-lg-0 fw-bold text-center text-lg-start">
                    <li class="nav-item"><a class="nav-link text-dark mx-2" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link text-dark mx-2" href="/gold">Gold</a></li>
                    <li class="nav-item"><a class="nav-link text-dark mx-2" href="/silver">Silver</a></li>
                    <li class="nav-item"><a class="nav-link text-dark mx-2" href="/artificial">Artificial</a></li>
                    <li class="nav-item"><a class="nav-link text-dark mx-2" href="/about">About Us</a></li>
                    <li class="nav-item"><a class="nav-link text-dark mx-2" href="/contact">Contact Us</a></li>
                </ul>

                <div class="d-none d-lg-flex align-items-center gap-4">
                    <form action="/search" method="GET" class="position-relative">
                        <input class="form-control rounded-pill border-0 bg-light" type="search" name="q" placeholder="Search jewellery..." required style="width: 220px; padding-right: 40px; font-size: 0.9rem;">
                        <button class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-muted shadow-none p-0 pe-3" type="submit" style="text-decoration:none;"><i class="fas fa-search"></i></button>
                    </form>

                    <div class="d-flex align-items-center gap-3">
                        <a href="/wishlist" class="text-dark position-relative">
                            <i class="far fa-heart fs-5"></i>
                        </a>
                        
                        <a href="/cart" class="text-dark position-relative">
                            <i class="fas fa-shopping-bag fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                                <%= typeof cartItemCount !== 'undefined' ? cartItemCount : 0 %>
                            </span>
                        </a>
                    </div>

                    <% if (user) { %>
                        <div class="dropdown">
                            <a class="text-dark text-decoration-none fw-bold d-flex align-items-center dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="far fa-user fs-5 me-1"></i> Hi, <%= user.name.split(' ')[0] %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 rounded-3">
                                <% if (user.role === 'admin') { %>
                                    <li><a class="dropdown-item fw-bold text-danger py-2" href="/admin"><i class="fas fa-shield-alt me-2"></i>Admin Panel</a></li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                <% } %>
                                <li><a class="dropdown-item py-2" href="/profile"><i class="fas fa-user-circle me-2 text-muted"></i>My Profile</a></li>
                                <li><a class="dropdown-item py-2" href="/orders"><i class="fas fa-box me-2 text-muted"></i>My Orders</a></li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <li><a class="dropdown-item text-danger fw-bold py-2" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/login" class="text-dark text-decoration-none fw-bold d-flex align-items-center">
                            <i class="far fa-user fs-5 me-2"></i> Login
                        </a>
                    <% } %>
                </div>

                <% if (user) { %>
                    <div class="d-lg-none border-top mt-3 pt-3 pb-2 text-center">
                        <span class="text-muted small fw-bold d-block mb-2 text-uppercase">My Account</span>
                        <% if (user.role === 'admin') { %>
                            <a class="nav-link text-danger fw-bold py-2" href="/admin"><i class="fas fa-shield-alt me-2"></i>ADMIN PANEL</a>
                        <% } %>
                        <a class="nav-link text-dark py-2" href="/profile"><i class="fas fa-user-circle me-2"></i>My Profile</a>
                        <a class="nav-link text-dark py-2" href="/orders"><i class="fas fa-box me-2"></i>My Orders</a>
                        <a class="nav-link text-danger fw-bold py-2 mt-2" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a>
                    </div>
                <% } else { %>
                    <div class="d-lg-none border-top mt-3 pt-3 pb-2 text-center">
                        <a class="btn btn-dark rounded-pill w-100 fw-bold" href="/login" style="background-color: #2c3e50;">Login / Sign Up</a>
                    </div>
                <% } %>

            </div>
        </div>
    </nav>