<style>
  .smj-floating-tooltip {
      position: fixed;
      bottom: 95px; 
      right: 25px;  
      background-color: #ffffff;
      color: #000000;
      padding: 8px 16px;
      border-radius: 20px;
      box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
      font-family: Arial, sans-serif;
      font-size: 13px;
      font-weight: 600;
      z-index: 999999; 
      pointer-events: none; 
      animation: upDown 2s infinite ease-in-out; 
      transition: opacity 0.3s ease; 
      opacity: 1; 
  }

  .smj-floating-tooltip::after {
      content: '';
      position: absolute;
      bottom: -6px;
      right: 18px;
      width: 0;
      height: 0;
      border-left: 6px solid transparent;
      border-right: 6px solid transparent;
      border-top: 6px solid #ffffff;
  }

  @keyframes upDown {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
  }
</style>

<script>
  const smjTooltip = document.getElementById('smj-tooltip');
  
  let isChatOpen = false;
  let isMouseNear = false;

  document.addEventListener('mousemove', function(e) {
      if (window.innerWidth - e.clientX < 130 && window.innerHeight - e.clientY < 130) {
          isMouseNear = true;
      } else {
          isMouseNear = false;
      }
      checkAndShowTooltip(); 
  });

  setInterval(() => {
      let detectedOpen = false;
      const elements = document.querySelectorAll('iframe, div[id*="bp-web"], div[id*="botpress"]');
      
      for (let el of elements) {
          if (el.clientHeight > 250) {
              detectedOpen = true;
              break;
          }
      }
      
      if (detectedOpen !== isChatOpen) {
          isChatOpen = detectedOpen;
          checkAndShowTooltip(); 
      }
  }, 300);

  function checkAndShowTooltip() {
      if (!smjTooltip) return;

      if (isChatOpen) {
          smjTooltip.style.opacity = '0';
      } else {
          if (isMouseNear) {
              smjTooltip.style.opacity = '0';
          } else {
              smjTooltip.style.opacity = '1';
          }
      }
  }
</script>
   
