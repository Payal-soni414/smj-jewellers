    <script>
    async function toggleWishlist(productId, btnElement) {
        const icon = btnElement.querySelector('i');
        // Animation ke liye turant class badlo
        const isLiked = icon.classList.contains('fas');
        
        if (isLiked) {
            icon.classList.remove('fas');
            icon.classList.add('far');
        } else {
            icon.classList.remove('far');
            icon.classList.add('fas');
        }

        try {
            const response = await fetch('/api/wishlist/toggle/' + productId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();
            
            if (!data.success && data.message === 'login_required') {
                window.location.href = '/login';
                return;
            }

            // Wishlist Badge update
            const badge = document.querySelector('a[href="/wishlist"] .badge');
            if (badge && data.success) {
                let count = parseInt(badge.innerText) || 0;
                badge.innerText = data.action === 'added' ? count + 1 : count - 1;
            }
        } catch (err) {
            console.error("Wishlist error:", err);
        }
    }
</script>
    
