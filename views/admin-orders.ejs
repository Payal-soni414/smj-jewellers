<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Management | SMJ Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @media (max-width: 576px) {
            .status-form { flex-direction: column !important; align-items: stretch !important; gap: 8px; }
            .status-form select { width: 100% !important; margin-right: 0 !important; }
            .status-form button { width: 100% !important; border-radius: 5px !important; }
        }
    </style>
</head>
<body class="bg-light">

<div class="d-flex flex-column flex-lg-row" id="wrapper">
    
    <%- include('partials/admin-sidebar') %>

    <div id="page-content-wrapper" class="w-100 overflow-hidden bg-light">
        
        <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 px-4 shadow-sm mb-4">
            <h4 class="mb-0 fw-bold"><a href="/admin" class="text-dark text-decoration-none"><i class="fas fa-arrow-left me-3"></i></a> Order Management</h4>
        </nav>

        <div class="container-fluid px-2 px-lg-4 pb-5">
            
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4 gap-2">
                <h5 class="fw-bold mb-0 text-muted">All Customer Orders</h5>
                <span class="badge bg-dark px-3 py-2 fs-6 rounded-pill align-self-start align-self-sm-auto">
                    <%= orders.length %> Total Orders
                </span>
            </div>
            
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="min-width: 800px;">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="py-3 px-4">Order Details</th>
                                <th class="py-3">Customer Info</th>
                                <th class="py-3">Amount</th>
                                <th class="py-3">Payment</th>
                                <th class="py-3">Status Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (orders && orders.length > 0) { %>
                                <% orders.forEach(order => { %>
                                    <tr>
                                        <td class="px-4 py-3">
                                            <span class="fw-bold text-dark d-block" style="font-family: monospace; font-size: 16px;">
                                                #<%= order._id.toString().substring(0,8).toUpperCase() %>
                                            </span>
                                            <span class="small text-muted">
                                                <i class="far fa-calendar-alt me-1"></i> 
                                                <%= new Date(order.orderDate).toLocaleDateString('en-IN') %>
                                            </span><br>
                                            <span class="badge bg-secondary mt-1">
                                                <%= order.items.length %> Item(s)
                                            </span>
                                        </td>
                                        
                                        <td class="py-3">
                                            <span class="fw-bold d-block text-dark">
                                                <%= order.shippingAddress.fullName %>
                                            </span>
                                            <span class="small text-muted">
                                                <i class="fas fa-phone-alt me-1"></i> 
                                                <%= order.shippingAddress.phone %>
                                            </span><br>
                                            <span class="small text-muted">
                                                <i class="fas fa-map-marker-alt me-1 text-danger"></i> 
                                                <%= order.shippingAddress.city %>, <%= order.shippingAddress.pincode %>
                                            </span>
                                        </td>

                                        <td class="py-3">
                                            <span class="fw-bold fs-5" style="color: #d4af37;">
                                                ₹ <%= Math.round(order.totalAmount).toLocaleString('en-IN') %>
                                            </span>
                                        </td>

                                        <td class="py-3">
                                            <span class="badge border border-dark text-dark bg-light px-2 py-1">
                                                <i class="fas fa-money-bill-wave text-success me-1"></i> 
                                                <%= order.paymentMethod %>
                                            </span>
                                        </td>

                                        <td class="py-3 pe-4">
                                            <form action="/admin/orders/update-status/<%= order._id %>" method="POST" class="d-flex align-items-center status-form">
                                                
                                                <select name="status" 
                                                    class="form-select form-select-sm border-0 bg-light fw-bold shadow-sm me-2 <%= 
                                                        order.orderStatus === 'Processing' ? 'text-warning' : 
                                                        order.orderStatus === 'Shipped' ? 'text-primary' : 
                                                        order.orderStatus === 'Delivered' ? 'text-success' : 
                                                        'text-danger' 
                                                    %>" 
                                                    style="width:140px;">
                                                    <option value="Processing" <%= order.orderStatus === 'Processing' ? 'selected' : '' %>>Processing</option>
                                                    <option value="Shipped" <%= order.orderStatus === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                                                    <option value="Delivered" <%= order.orderStatus === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                                                    <option value="Cancelled" <%= order.orderStatus === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                                </select>

                                                <button type="submit" class="btn btn-sm btn-dark rounded-circle shadow-sm flex-shrink-0" style="width: 32px; height: 32px;" title="Update Status">
                                                    <i class="fas fa-check"></i> 
                                                    <span class="d-inline d-sm-none ms-1">Update</span>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fas fa-box-open fs-1 mb-3 opacity-25"></i>
                                        <h5>No orders received yet</h5>
                                        <p class="small">When customers place an order, it will appear here.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>