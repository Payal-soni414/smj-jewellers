<%- include('partials/header') %>

<div class="bg-light py-4 border-bottom">
    <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
        <h2 class="fw-bold text-uppercase mb-0 text-center text-sm-start w-100 w-sm-auto" style="color: #2c3e50;">Gold Collection</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Home</a></li>
                <li class="breadcrumb-item active fw-bold" style="color: #d4af37;">Gold</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        
        <div class="col-lg-3 mb-4">
            
            <button class="btn btn-dark w-100 d-lg-none mb-3 fw-bold shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse" style="background-color: #2c3e50; border: none;">
                <i class="fas fa-filter me-2 text-warning"></i> Show/Hide Filters
            </button>

            <form action="/gold" method="GET" class="card border-0 shadow-sm p-4 rounded-4 sticky-lg-top collapse d-lg-block" id="filterCollapse" style="top: 100px; z-index: 1;">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                    <h5 class="fw-bold mb-0 d-none d-lg-block"><i class="fas fa-filter me-2 text-warning"></i>Filters</h5>
                    <a href="/gold" class="text-danger small text-decoration-none ms-auto">Clear All</a>
                </div>
                
                <div class="mb-4 pe-2" style="max-height: 250px; overflow-y: auto;">
                    <h6 class="fw-bold text-muted mb-3">Categories</h6>
                    <% const categoriesList = ['Rings', 'Necklace', 'Pendant', 'Chains', 'Earrings', 'Nose Ring', 'Bangles', 'Mangalsutra', 'Bracelets', 'Anklet', 'Bridal Jewellery']; %>
                    <% categoriesList.forEach(cat => { %>
                        <div class="form-check mb-2">
                            <input class="form-check-input border-secondary" type="checkbox" name="cat" value="<%= cat %>" id="g_<%= cat.replace(/\s+/g, '') %>">
                            <label class="form-check-label small" for="g_<%= cat.replace(/\s+/g, '') %>"><%= cat %></label>
                        </div>
                    <% }); %>
                </div>
                
                <div class="mb-4">
                    <h6 class="fw-bold text-muted mb-2">Price Range</h6>
                    <div class="form-check mb-1">
                        <input class="form-check-input border-secondary" type="radio" name="price" value="under20000" id="p1">
                        <label class="form-check-label small" for="p1">Under ₹20,000</label>
                    </div>
                    <div class="form-check mb-1">
                        <input class="form-check-input border-secondary" type="radio" name="price" value="20000to50000" id="p2">
                        <label class="form-check-label small" for="p2">₹20,000 - ₹50,000</label>
                    </div>
                    <div class="form-check mb-4">
                        <input class="form-check-input border-secondary" type="radio" name="price" value="above50000" id="p3">
                        <label class="form-check-label small" for="p3">Above ₹50,000</label>
                    </div>
                </div>
                
                <div class="mb-4">
                    <h6 class="fw-bold text-muted mb-2">Sort By Price</h6>
                    <select name="sort" class="form-select bg-light border-0 small shadow-sm">
                        <option value="">Default (Newest)</option>
                        <option value="lowToHigh">Price: Low to High</option>
                        <option value="highToLow">Price: High to Low</option>
                    </select>
                </div>
                
                <button type="submit" class="btn w-100 rounded-pill mt-2 fw-bold text-dark shadow-sm" style="background-color: #d4af37; border: none;">Apply Filters</button>
            </form>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="text-muted fw-bold">Showing <%= products ? products.length : 0 %> results</span>
            </div>
            
            <div class="row g-4">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(item => { %>
                        <div class="col-sm-6 col-lg-4">
                            <div class="card border-0 shadow-sm h-100 product-card" style="border-radius: 15px; overflow: hidden;">
                                <div class="position-relative">
                                    <% if (!item.inStock) { %>
                                        <span class="badge bg-danger position-absolute top-0 start-0 m-2 px-3 py-2 shadow" style="z-index: 1;">
                                            <i class="fas fa-ban me-1"></i> Out of Stock
                                        </span>
                                    <% } %>
                                    
                                    <a href="/product/<%= item._id %>" class="d-block overflow-hidden">
                                        <img src="<%= item.imagePath %>" class="card-img-top <%= !item.inStock ? 'opacity-75' : '' %>" alt="<%= item.name %>" style="height: 280px; object-fit: cover;">
                                    </a>
                                    
                                    <% let isLiked = (typeof userWishlist !== 'undefined' && userWishlist.includes(item._id.toString())); %>
                                    <button onclick="toggleWishlist('<%= item._id %>', this)" class="btn btn-light rounded-circle shadow-sm position-absolute top-0 end-0 m-2 border-0" style="z-index:10; width:40px; height:40px; display:flex; align-items:center; justify-content:center; transition: all 0.3s ease;">
                                        <i class="<%= isLiked ? 'fas' : 'far' %> fa-heart text-danger"></i>
                                    </button>
                                </div>
                                
                                <div class="card-body text-center bg-white pb-4 d-flex flex-column">
                                    <a href="/product/<%= item._id %>" class="text-decoration-none">
                                        <h6 class="card-title fw-bold mb-1 text-dark"><%= item.name %></h6>
                                    </a>
                                    <p class="text-muted small mb-1"><%= item.weightInGrams %>g | 22K Gold</p>
                                    <h5 class="text-dark fw-bold mb-3 mt-auto">₹ <%= Math.round(item.calculatedPrice).toLocaleString('en-IN') %></h5>
                                    
                                    <% if (item.inStock) { %>
                                        <form action="/cart/add/<%= item._id %>" method="POST" class="mt-auto">
                                            <button type="submit" class="btn btn-outline-dark btn-sm w-100 rounded-pill fw-bold">
                                                <i class="fas fa-shopping-cart me-2"></i>Add to Cart
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <div class="mt-auto">
                                            <button class="btn btn-secondary btn-sm w-100 rounded-pill fw-bold" disabled>
                                                <i class="fas fa-box-open me-2"></i> Out of Stock
                                            </button>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <i class="fas fa-search-minus fs-1 text-muted mb-3 opacity-50"></i>
                        <p class="lead fw-bold text-muted">No gold products found matching your filter.</p>
                        <a href="/gold" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">Clear Filters</a>
                    </div>
                <% } %>
            </div>
            
           <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <nav class="mt-5">
        <ul class="pagination justify-content-center flex-wrap">
            
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                <a class="page-link shadow-sm" href="?page=<%= currentPage - 1 %>">Previous</a>
            </li>
            
            <% for(let i = 1; i <= totalPages; i++) { %>
                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link <%= currentPage === i ? 'bg-dark border-dark text-white' : 'text-dark' %> shadow-sm" href="?page=<%= i %>"><%= i %></a>
                </li>
            <% } %>
            
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                <a class="page-link text-dark shadow-sm" href="?page=<%= currentPage + 1 %>">Next</a>
            </li>
            
        </ul>
    </nav>
<% } %>
        </div>
    </div>
</div>

<style>
    .product-card { transition: all 0.3s; display: flex; flex-direction: column; }
    .product-card:hover { transform: translateY(-8px); box-shadow: 0 12px 25px rgba(0,0,0,0.12) !important; }
    .page-link { border-radius: 50% !important; margin: 0 5px; color: black; font-weight: bold; }
    
    /* Scrollbar styling for filters */
    .pe-2::-webkit-scrollbar { width: 6px; }
    .pe-2::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 10px; }
    .pe-2::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 10px; }
</style>

<script>
async function toggleWishlist(productId, btn) {
    try {
        const response = await fetch(`/api/wishlist/toggle/${productId}`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        
        if (data.message === 'login_required') { 
            window.location.href = '/login'; 
            return; 
        }

        if (data.success) {
            const icon = btn.querySelector('i');
            
            // Ab sirf Dil (Heart) laal ya khali hoga, koi number change nahi hoga
            if (data.action === 'added') {
                icon.classList.replace('far', 'fas');
            } else {
                icon.classList.replace('fas', 'far');
            }
        }
    } catch (err) { console.error(err); }
}
</script>
<%- include('partials/footer') %>