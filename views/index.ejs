<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shree Mahalakshmi Jewellers</title>
    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/header') %>

<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="2500" data-bs-pause="false">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active slider-img-bg" style="background-image: url('/images/slider1.png');">
            <div style="position: absolute; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.5);"></div>
            <div class="container h-100 d-flex flex-column align-items-center justify-content-center text-center position-relative px-3" style="z-index: 2;">
                <h3 class="text-warning mb-2 mb-md-3 fs-5 fs-md-3" style="letter-spacing: 3px; font-family: serif;">WELCOME TO</h3>
                <h1 class="text-white fw-bold mb-3 mb-md-4 hero-title" style="text-shadow: 2px 2px 8px rgba(0,0,0,0.8);">Shree Mahalakshmi Jewellers</h1>
                <p class="lead text-light mb-4 mb-md-5 fs-6 fs-md-4 px-2">Tradition you can trust, Elegance you can wear.</p>
                <a href="/gold" class="btn rounded-pill px-4 px-md-5 py-2 py-md-3 fw-bold custom-hero-btn" style="background-color: #d4af37; color: white; transition: 0.3s; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);">Explore Collection</a>
            </div>
        </div>
        <div class="carousel-item slider-img-bg" style="background-image: url('/images/slider2.jpg');">
            <div style="position: absolute; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.4);"></div>
            <div class="container h-100 d-flex flex-column align-items-center justify-content-center text-center position-relative px-3" style="z-index: 2;">
                <h1 class="text-white fw-bold mb-3 hero-title">Royal Collection</h1>
                <p class="lead text-light mb-4 fs-6 fs-md-4">Inspired by the heritage of Rajasthan.</p>
                <a href="/gold" class="btn btn-outline-light rounded-pill px-4 px-md-5 py-2 py-md-3 fw-bold border-2">Shop Bridal</a>
            </div>
        </div>
        <div class="carousel-item slider-img-bg" style="background-image: url('/images/slider3.jpg');">
            <div style="position: absolute; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.5);"></div>
            <div class="container h-100 d-flex flex-column align-items-center justify-content-center text-center position-relative px-3" style="z-index: 2;">
                <h1 class="text-white fw-bold mb-3 hero-title">Premium Silver</h1>
                <p class="lead text-light mb-4 fs-6 fs-md-4">Modern designs for the modern woman.</p>
                <a href="/silver" class="btn btn-outline-light rounded-pill px-4 px-md-5 py-2 py-md-3 fw-bold border-2">View More</a>
            </div>
        </div>
        <div class="carousel-item slider-img-bg" style="background-image: url('/images/slider4.jpg');">
            <div style="position: absolute; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.5);"></div>
            <div class="container h-100 d-flex flex-column align-items-center justify-content-center text-center position-relative px-3" style="z-index: 2;">
                <h1 class="text-white fw-bold mb-3 hero-title">Exquisite Artificial Range</h1>
                <p class="lead text-light mb-4 fs-6 fs-md-4">Flawless beauty for every special moment.</p>
                <a href="/artificial" class="btn btn-outline-light rounded-pill px-4 px-md-5 py-2 py-md-3 fw-bold border-2">Explore Now</a>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<section class="py-5 bg-light" style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png');">
    <div class="container px-3">
        <div class="text-center mb-4 mb-md-5">
            <h3 class="fw-bold fs-4 fs-md-3" style="color: #2c3e50; font-family: serif;">Today's Market Rates</h3>
            <div style="height: 2px; width: 50px; background-color: #d4af37; margin: 5px auto;"></div>
        </div>
        <div class="row justify-content-center g-3 g-md-4">
            <div class="col-12 col-md-5">
                <div class="card border-0 shadow-sm p-3 p-md-4 text-center h-100" style="background: linear-gradient(to right, #fff, #fffbec); border-radius: 15px; border-left: 5px solid #d4af37;">
                    <h5 class="text-muted fw-bold mb-2 mb-md-3"><i class="fas fa-coins text-warning me-2"></i>22K Gold Rate</h5>
                    <h2 class="fw-bold text-dark mb-0 fs-2 fs-md-1">₹ <%= liveRate.goldRate22K ? Math.round(liveRate.goldRate22K).toLocaleString('en-IN') : 0 %> <span class="fs-6 fs-md-5 text-muted">/gm</span></h2>
                </div>
            </div>
            <div class="col-12 col-md-5">
                <div class="card border-0 shadow-sm p-3 p-md-4 text-center h-100" style="background: linear-gradient(to right, #fff, #f2f4f7); border-radius: 15px; border-left: 5px solid #6c757d;">
                    <h5 class="text-muted fw-bold mb-2 mb-md-3"><i class="fas fa-ring text-secondary me-2"></i>Silver Rate</h5>
                    <h2 class="fw-bold text-dark mb-0 fs-2 fs-md-1">₹ <%= liveRate.silverRate ? Math.round(liveRate.silverRate).toLocaleString('en-IN') : 0 %> <span class="fs-6 fs-md-5 text-muted">/kg</span></h2>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container py-2 py-md-3 px-3">
        <div class="text-center mb-4 mb-md-5">
            <h2 class="fw-bold mb-2 collection-title" style="color: #4a2323; font-family: 'Times New Roman', serif;">Shree Mahalakshmi Collections</h2>
            <p class="text-muted small fs-md-6">Explore our beautifully crafted jewellery categories</p>
        </div>
        <div class="row g-3 g-md-4">
            <div class="col-lg-6">
                <a href="/gold" class="text-decoration-none d-block h-100">
                    <div class="collection-card position-relative overflow-hidden rounded-4 shadow-sm h-100">
                        <img src="https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=800&auto=format&fit=crop" class="w-100 collection-img gold-img" alt="Gold Collection">
                        <div class="collection-overlay position-absolute bottom-0 start-0 w-100 p-4 p-md-5 text-start" style="background: linear-gradient(transparent, rgba(0,0,0,0.8));">
                            <h2 class="text-white fw-bold fs-3 fs-md-2">Gold Collection</h2>
                            <p class="text-white mb-0">Explore Now <i class="fas fa-chevron-right ms-1 small"></i></p>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-lg-6 d-flex flex-column gap-3 gap-md-4 mt-3 mt-lg-0">
                <a href="/silver" class="text-decoration-none d-block flex-grow-1">
                    <div class="collection-card position-relative overflow-hidden rounded-4 shadow-sm h-100">
                        <img src="https://images.unsplash.com/photo-1603561596112-0a132b757442?w=800&auto=format&fit=crop" class="w-100 collection-img sub-img" alt="Silver Collection">
                        <div class="collection-overlay position-absolute bottom-0 start-0 w-100 p-3 p-md-4 text-start" style="background: linear-gradient(transparent, rgba(0,0,0,0.8));">
                            <h3 class="text-white fw-bold fs-4 fs-md-3 mb-0">Silver Collection</h3>
                        </div>
                    </div>
                </a>
                <a href="/artificial" class="text-decoration-none d-block flex-grow-1">
                    <div class="collection-card position-relative overflow-hidden rounded-4 shadow-sm h-100">
                        <img src="https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=800&auto=format&fit=crop" class="w-100 collection-img sub-img" alt="Artificial Collection">
                        <div class="collection-overlay position-absolute bottom-0 start-0 w-100 p-3 p-md-4 text-start" style="background: linear-gradient(transparent, rgba(0,0,0,0.8));">
                            <h3 class="text-white fw-bold fs-4 fs-md-3 mb-0">Artificial Range</h3>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container px-3">
        <div class="rounded-4 overflow-hidden shadow-sm position-relative d-flex justify-content-center align-items-center" style="max-height: 550px; background-color: #000;">
            <video class="w-100" style="object-fit: cover; opacity: 0.9;" autoplay loop muted playsinline>
                <source src="/videos/video1.mp4" type="video/mp4">
            </video>
            <div class="position-absolute text-center px-2" style="pointer-events: none;">
                <h2 class="text-white fw-bold video-title" style="text-shadow: 2px 2px 10px rgba(0,0,0,0.8); font-family: serif; letter-spacing: 2px;">Crafted for Eternity</h2>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container py-2 py-md-4 px-3">
        <div class="text-center mb-4 mb-md-5">
            <h2 class="fw-bold text-uppercase fs-3 fs-md-2" style="color: #2c3e50; font-family: serif;">Trending Now</h2>
            <div style="height: 3px; width: 60px; background-color: #d4af37; margin: 10px auto;"></div>
        </div>
        
        <div class="row g-3 g-md-4">
            <% if (typeof trendingProducts !== 'undefined' && trendingProducts.length > 0) { %>
                <% trendingProducts.forEach(product => { %>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm h-100 position-relative collection-card rounded-4 overflow-hidden">
                            
                            <% if (!product.inStock) { %>
                                <span class="badge bg-danger position-absolute top-0 start-0 m-3 shadow-sm" style="z-index: 5;">
                                    <i class="fas fa-ban me-1"></i> Out of Stock
                                </span>
                            <% } %>

                            <% 
                                let isWished = false;
                                if(typeof userWishlist !== 'undefined' && userWishlist.includes(product._id.toString())) {
                                    isWished = true;
                                }
                            %>
                            
                            <button type="button" onclick="toggleWishlist('<%= product._id %>', this)" class="btn position-absolute top-0 end-0 m-2 m-md-3 z-3 bg-white rounded-circle p-2 shadow-sm border-0" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; transition: 0.3s;">
                                <i id="heart-icon-<%= product._id %>" class="<%= isWished ? 'fas' : 'far' %> fa-heart text-danger"></i>
                            </button>

                            <a href="/product/<%= product._id %>" class="overflow-hidden d-block text-center">
                                <img src="<%= product.imagePath %>" class="card-img-top collection-img <%= !product.inStock ? 'opacity-75' : '' %>" alt="<%= product.name %>" style="height: 250px; object-fit: cover;">
                            </a>

                            <div class="card-body text-center bg-white d-flex flex-column p-3 p-md-4">
                                <h6 class="card-title fw-bold mb-1 text-truncate">
                                    <a href="/product/<%= product._id %>" class="text-dark text-decoration-none"><%= product.name %></a>
                                </h6>
                                <p class="text-muted small mb-1"><%= product.category %> Jewellery</p>
                                <% if(product.category === 'Gold' || product.category === 'Silver') { %>
                                    <p class="text-muted small fw-bold mb-1" style="color: #d4af37 !important;">Weight: <%= product.weightInGrams %>g</p>
                                <% } %>
                                <h5 class="text-dark fw-bold mb-3 mt-auto fs-6 fs-md-5">₹ <%= Math.round(product.calculatedPrice).toLocaleString('en-IN') %></h5>
                                
                                <% if (product.inStock) { %>
                                    <form action="/cart/add/<%= product._id %>" method="POST" class="mt-auto">
                                        <button type="submit" class="btn btn-outline-dark w-100 rounded-pill fw-bold btn-sm py-2 shadow-sm">
                                            <i class="fas fa-shopping-cart me-2"></i>Add to Cart
                                        </button>
                                    </form>
                                <% } else { %>
                                    <div class="mt-auto">
                                        <button class="btn btn-secondary w-100 rounded-pill fw-bold btn-sm py-2 shadow-sm" disabled>
                                            <i class="fas fa-box-open me-2"></i> Out of Stock
                                        </button>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <i class="fas fa-box-open fa-3x text-muted mb-3 opacity-50"></i>
                    <h5 class="text-muted">No trending items right now.</h5>
                </div>
            <% } %>
        </div>
    </div>
</section>

<style>
    /* Nayi class mobile me slider images theek karne ke liye */
    .slider-img-bg {
        height: 55vh; /* Mobile height */
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
    }

    .hero-title { font-size: 2.2rem; }
    .collection-title { font-size: 1.8rem; }
    .video-title { font-size: 1.8rem; }
    .gold-img { height: 350px; object-fit: cover; }
    .sub-img { height: 220px; object-fit: cover; }

    @media (min-width: 768px) {
        .slider-img-bg { height: 85vh; /* Desktop height */ }
        .hero-title { font-size: 4rem; }
        .collection-title { font-size: 2.8rem; }
        .video-title { font-size: 3rem; }
    }
    
    @media (min-width: 992px) {
        .gold-img { height: 624px; }
        .sub-img { height: 300px; }
    }

    .collection-card { cursor: pointer; transition: 0.3s; }
    .collection-img { transition: transform 0.6s ease; }
    .collection-card:hover .collection-img { transform: scale(1.05); }
    .collection-card:hover { transform: translateY(-8px); box-shadow: 0 12px 25px rgba(0,0,0,0.12) !important; }
    .custom-hero-btn:hover { background-color: #b8962e !important; transform: translateY(-2px); }
</style>

<script>
async function toggleWishlist(productId, btn) {
    try {
        const response = await fetch(`/api/wishlist/toggle/${productId}`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        
        if (data.message === 'login_required') { 
            window.location.href = '/login'; 
            return; 
        }

        if (data.success) {
            const icon = btn.querySelector('i');
            
            // Ab sirf Dil (Heart) laal ya khali hoga, koi number change nahi hoga
            if (data.action === 'added') {
                icon.classList.replace('far', 'fas');
            } else {
                icon.classList.replace('fas', 'far');
            }
        }
    } catch (err) { console.error(err); }
}
</script>

<%- include('partials/footer') %>
</body>
</html>