<%- include('partials/header') %>

<div class="bg-light py-4 border-bottom">
    <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
        <h2 class="fw-bold text-uppercase mb-0 fs-3 fs-md-2" style="color: #2c3e50;">
            <i class="fas fa-heart me-2 text-danger"></i>My Wishlist
        </h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Home</a></li>
                <li class="breadcrumb-item active fw-bold" style="color: #d4af37;">Wishlist</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <% if (wishlist && wishlist.items.length > 0) { %>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                <% wishlist.items.forEach(item => { %>
                    <% let product = item.productId; %>
                    
                    <% if(product) { %> 
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm rounded-4 product-card overflow-hidden">
                                <div class="position-relative">
                                    
                                    <% if (!product.inStock) { %>
                                        <span class="badge bg-danger position-absolute top-0 start-0 m-2 px-3 py-2 shadow-sm" style="z-index: 5;">
                                            <i class="fas fa-ban me-1 text-white"></i> Out of Stock
                                        </span>
                                    <% } %>

                                    <a href="/product/<%= product._id %>" class="d-block text-center bg-light p-2">
                                        <img src="<%= product.imagePath %>" class="card-img-top wishlist-img <%= !product.inStock ? 'opacity-75' : '' %>" alt="<%= product.name %>" style="height: 220px; object-fit: contain;">
                                    </a>
                                    
                                    <span class="position-absolute bottom-0 start-0 m-2 badge bg-white text-dark shadow-sm border small opacity-75">
                                        <%= product.category %>
                                    </span>
                                </div>

                                <div class="card-body text-center d-flex flex-column p-3">
                                    <a href="/product/<%= product._id %>" class="text-decoration-none text-dark">
                                        <h6 class="card-title fw-bold mb-1 text-truncate"><%= product.name %></h6>
                                    </a>

                                    <div class="mb-3">
                                        <% if (product.category !== 'Artificial') { %>
                                            <span class="text-muted small fw-bold"><i class="fas fa-balance-scale me-1"></i><%= product.weightInGrams %>g</span>
                                        <% } else { %>
                                            <span class="text-muted small fw-bold">Premium Range</span>
                                        <% } %>
                                    </div>
                                    
                                    <div class="mt-auto d-grid gap-2">
                                        <% if (product.inStock) { %>
                                            <form action="/cart/add/<%= product._id %>" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold btn-sm py-2 shadow-sm move-cart-btn" style="background-color: #d4af37; border: none;">
                                                    <i class="fas fa-shopping-cart me-2"></i>Move to Cart
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <button class="btn btn-secondary w-100 rounded-pill fw-bold btn-sm py-2" disabled>
                                                <i class="fas fa-box-open me-2"></i> Stock Out
                                            </button>
                                        <% } %>

                                        <form action="/wishlist/remove/<%= product._id %>" method="POST" class="m-0">
                                            <button type="submit" class="btn btn-link text-danger text-decoration-none small fw-bold p-0 remove-btn">
                                                <i class="fas fa-trash-alt me-1"></i>Remove
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                <% }) %>
            </div>
            
        <% } else { %>
            <div class="col-12 text-center py-5">
                <div class="mb-4">
                    <i class="far fa-heart display-1 text-muted opacity-25"></i>
                </div>
                <h3 class="fw-bold text-dark">Your Wishlist is Empty</h3>
                <p class="text-muted mb-4 px-3">You haven't added any items to your wishlist yet. Explore our collections and find something you love!</p>
                <a href="/" class="btn btn-dark rounded-pill px-5 py-2 fw-bold shadow-sm" style="background-color: #2c3e50; border: none;">Explore Products</a>
            </div>
        <% } %>
    </div>
</div>

<style>
    /* Card Hover Effects */
    .product-card { transition: all 0.3s ease; border: 1px solid #f1f1f1 !important; }
    .product-card:hover { transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important; }
    
    .wishlist-img { transition: transform 0.5s ease; }
    .product-card:hover .wishlist-img { transform: scale(1.05); }

    .move-cart-btn:hover { background-color: #b8962e !important; }
    .remove-btn:hover { color: #842029 !important; }

    /* For clean text on small screens */
    .text-truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
</style>

<%- include('partials/footer') %>