<%- include('partials/header') %>

<div class="container py-5 mt-4 mt-md-5">
    <div class="row justify-content-center">
        <div class="col-11 col-sm-8 col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 p-md-5 mt-3 mt-md-5">
                
                <div class="text-center mb-4">
                    <i class="fas fa-lock fa-3x text-warning"></i>
                </div>
                <h3 class="text-center fw-bold mb-3 fs-4 fs-md-3" style="color: #2c3e50;">Forgot Password?</h3>
                <p class="text-center text-muted mb-4 small px-2">Enter your registered email address and we will send you a 4-digit OTP to reset your password.</p>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm text-center small fw-bold rounded-3 mb-4" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <form action="/forgot-password" method="POST">
                    <div class="mb-4">
                        <label class="form-label fw-bold small" style="color: #2c3e50;">Email Address</label>
                        <input type="email" name="email" class="form-control py-2 py-md-3 shadow-sm border-0 bg-light rounded-3" required placeholder="Enter your registered email">
                    </div>
                    
                    <button type="submit" class="btn btn-dark w-100 py-2 py-md-3 fw-bold rounded-pill shadow-sm custom-btn" style="background-color: #2c3e50; border: none; transition: 0.3s;">
                        Send OTP <i class="fas fa-paper-plane ms-2 text-warning"></i>
                    </button>
                </form>
                
                <div class="text-center mt-4">
                    <a href="/login" class="text-decoration-none text-muted small fw-bold hover-warning" style="transition: 0.3s;">
                        <i class="fas fa-arrow-left me-1"></i> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Button & Link Hover Effects */
    .custom-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(44, 62, 80, 0.4) !important;
        background-color: #1a252f !important;
    }
    .hover-warning:hover {
        color: #d4af37 !important;
    }
</style>

<%- include('partials/footer') %>