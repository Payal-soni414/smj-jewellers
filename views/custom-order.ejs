
<%- include('partials/header') %>

<div class="bg-light py-4 py-md-5 border-bottom">
    <div class="container text-center px-3">
        <h2 class="fw-bold text-uppercase mb-2 fs-3 fs-md-2" style="color: #2c3e50;">Design Your Dream Jewellery</h2>
        <p class="text-muted small fs-md-6 mb-0">Upload photos (optional) of your desired design, and our expert karigars will bring it to life.</p>
    </div>
</div>

<div class="container py-5 px-3 px-md-auto">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-3" style="border-bottom: 4px solid #d4af37;">
                    <h4 class="mb-0 fw-bold fs-5 fs-md-4"><i class="fas fa-magic me-2 text-warning"></i>Custom Order Request</h4>
                </div>
                
                <div class="card-body p-3 p-md-5 bg-white">
                    <form action="/custom-order" method="POST" enctype="multipart/form-data">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Your Name</label>
                            <input type="text" name="customerName" value="<%= user ? user.name : '' %>" class="form-control bg-light border-0 py-2 rounded-3" required placeholder="Enter your full name">
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Phone Number</label>
                            <input type="tel" name="phone" class="form-control bg-light border-0 py-2 rounded-3" required placeholder="For our team to contact you">
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Upload Design Photos <span class="text-success">(Optional)</span></label>
                            <input type="file" name="designImage" class="form-control bg-light border-0 border-start border-4 border-warning py-2 rounded-3 shadow-sm" accept="image/*" multiple>
                            <small class="text-muted mt-2 d-block" style="line-height: 1.5;"><i class="fas fa-info-circle me-1"></i>You can select multiple pictures if you want. Leave empty if you don't have any.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Additional Details (Metal, Weight, Size etc.)</label>
                            <textarea name="details" rows="4" class="form-control bg-light border-0 rounded-3 shadow-sm" required placeholder="e.g. I want this in 22K Gold, approx weight 15 grams..."></textarea>
                        </div>

                        <button type="submit" class="btn w-100 fw-bold py-3 text-white rounded-pill shadow-sm custom-btn" style="background-color: #d4af37; font-size: 1.1rem; transition: 0.3s;">
                            <i class="fas fa-paper-plane me-2"></i> Submit Request
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(212, 175, 55, 0.4) !important;
        background-color: #b8962e !important;
    }
</style>

<%- include('partials/footer') %>