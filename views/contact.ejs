<%- include('partials/header') %>

<div class="bg-dark text-white py-5 text-center" style="background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('https://images.unsplash.com/photo-1599643478514-4a4e08d50153?auto=format&fit=crop&w=2000') center/cover;">
    <div class="container py-4 px-3">
        <h1 class="display-4 fw-bold text-warning mb-3">Get in Touch</h1>
        <p class="lead mb-0 fs-6 fs-md-5">We would love to hear from you for any jewellery enquiries or custom orders.</p>
    </div>
</div>

<div class="container py-5 my-md-4">
    <div class="row g-4 g-lg-5">
        
        <div class="col-lg-5">
            <h3 class="fw-bold mb-4 text-center text-lg-start" style="color: #2c3e50;">Contact Information</h3>
            <p class="text-muted mb-5 text-center text-lg-start">Have a question about a specific piece? Fill out the form and our team will get back to you within 24 hours.</p>
            
            <div class="d-flex flex-column align-items-center align-items-lg-start">
                <div class="text-start">
                    <div class="d-flex align-items-start mb-4">
                        <div class="bg-light p-3 rounded-circle text-warning fs-4 me-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Visit Our Store</h5>
                            <p class="text-muted mb-0">Gagrana Merta City<br>Nagaur, Rajasthan</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-start mb-4">
                        <div class="bg-light p-3 rounded-circle text-warning fs-4 me-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Call Us</h5>
                            <p class="text-muted mb-0">+91 9549589500<br>Mon - Sat (10:00 AM to 8:00 PM)</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-start mb-5">
                        <div class="bg-light p-3 rounded-circle text-warning fs-4 me-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Email Us</h5>
                            <p class="text-muted mb-0">support.smjewellers@gmail.com</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 rounded-4 overflow-hidden shadow-sm mt-4 mt-lg-0" style="background: linear-gradient(135deg, #2c3e50, #1a252f);">
                <div class="card-body p-4 text-center text-white">
                    <i class="fas fa-magic fa-2x text-warning mb-3"></i>
                    <h4 class="fw-bold text-warning">Want Your Own Design?</h4>
                    <p class="small text-light opacity-75 mb-4">Upload a photo of your dream jewellery and our Karigars will craft it exclusively for you.</p>
                    <a href="/custom-order" class="btn btn-outline-warning rounded-pill px-4 fw-bold shadow-sm">Request Custom Design</a>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 p-3 p-md-5">
                <h3 class="fw-bold mb-4 text-center" style="color: #2c3e50;">General Enquiry</h3>
                
                <form action="/contact" method="POST">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted small fw-bold">Full Name</label>
                            <input type="text" name="name" class="form-control bg-light border-0 py-2 rounded-3" placeholder="Enter your name" required>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted small fw-bold">Phone Number</label>
                            <input type="tel" name="phone" class="form-control bg-light border-0 py-2 rounded-3" placeholder="Enter phone number" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold">Email Address</label>
                            <input type="email" name="email" class="form-control bg-light border-0 py-2 rounded-3" placeholder="Enter your email" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold">Enquiry Type</label>
                            <select name="subject" class="form-select bg-light border-0 py-2 rounded-3 shadow-sm" required>
                                <option value="" selected disabled>Select an option...</option>
                                <option value="Gold Jewellery Enquiry">Gold Jewellery Enquiry</option>
                                <option value="Silver Jewellery Enquiry">Silver Jewellery Enquiry</option>
                                <option value="Artificial Jewellery Enquiry">Artificial Jewellery Enquiry</option>
                                <option value="Other Store Related">Other Store Related</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold">Your Message</label>
                            <textarea name="message" class="form-control bg-light border-0 rounded-3" rows="4" placeholder="Describe what you are looking for..." required></textarea>
                        </div>
                        <div class="col-12 mt-4">
                            <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold fs-5 text-white" style="background-color: #d4af37; transition: 0.3s; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);">
                                Send Enquiry <i class="fas fa-paper-plane ms-2"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<%- include('partials/footer') %>