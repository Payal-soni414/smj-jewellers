<%- include('partials/header') %>

<div class="container py-4 py-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                
                <div class="card-header border-bottom-0 py-3 text-center text-sm-start
                    <%= product.category === 'Gold' ? 'bg-warning text-dark' : 
                       (product.category === 'Silver' ? 'bg-secondary text-white' : 'bg-dark text-white') %>">
                    <h4 class="mb-0 fw-bold fs-5 fs-sm-4">
                        <i class="fas fa-edit me-2"></i>Edit <%= product.category %> Item
                    </h4>
                </div>
                
                <div class="card-body p-3 p-md-5 bg-light">
                    <form action="/admin/edit-product/<%= product._id %>" method="POST" enctype="multipart/form-data">
                        
                        <input type="hidden" name="category" value="<%= product.category %>">
                        <input type="hidden" name="description" value="">

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Product Name</label>
                            <input type="text" name="name" class="form-control bg-white border-0 py-2 shadow-sm" value="<%= product.name %>" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Update Image (Leave blank to keep current image)</label>
                            <input type="file" name="image" class="form-control bg-white border-0 py-2 shadow-sm" accept="image/*">
                            
                            <div class="mt-3 d-flex flex-column flex-sm-row align-items-center">
                                <span class="text-muted small me-0 me-sm-3 mb-2 mb-sm-0 fw-bold">Current Image:</span>
                                <img src="<%= product.imagePath %>" alt="<%= product.name %>" class="rounded shadow-sm border border-white border-3" style="height: 100px; width: 100px; object-fit: cover;">
                            </div>
                        </div>

                        <% if (product.category === 'Artificial') { %>
                            <input type="hidden" name="weightInGrams" value="0">

                            <div class="mb-4">
                                <label class="form-label fw-bold text-success small">Fixed Price ₹</label>
                                <input type="number" name="makingCharges" class="form-control bg-white border-0 border-start border-4 border-success py-2 shadow-sm" value="<%= product.makingCharges %>" required>
                            </div>

                        <% } else { %>
                            <div class="row g-3 mb-4">
                                <div class="col-12 col-sm-6">
                                    <label class="form-label fw-bold text-muted small">Weight (Grams)</label>
                                    <input type="number" step="0.001" name="weightInGrams" class="form-control bg-white border-0 py-2 shadow-sm" value="<%= product.weightInGrams %>" required>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label class="form-label fw-bold text-muted small">Making Charges ₹</label>
                                    <input type="number" name="makingCharges" class="form-control bg-white border-0 py-2 shadow-sm" value="<%= product.makingCharges %>" required>
                                </div>
                            </div>
                        <% } %>

                        <div class="d-flex flex-column flex-sm-row gap-3 mt-5">
                            <a href="/admin/manage-products" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold w-100 w-sm-50 shadow-sm">Cancel</a>
                            <button type="submit" class="btn btn-dark rounded-pill px-4 py-2 fw-bold w-100 w-sm-50 shadow-sm" style="background-color: #2c3e50; border: none;">Save Changes</button>
                        </div>
                        
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>