<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Enquiries | SMJ Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">

    <div class="d-flex flex-column flex-lg-row" id="wrapper">
        
        <%- include('partials/admin-sidebar') %>

        <div id="page-content-wrapper" class="w-100 overflow-hidden bg-light">
            
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 px-4 shadow-sm mb-4">
                <h4 class="mb-0 fw-bold"><a href="/admin" class="text-dark text-decoration-none"><i class="fas fa-arrow-left me-3"></i></a> Customer Enquiries</h4>
            </nav>

            <div class="container-fluid px-4 pb-5">
                <div class="row g-4">
                    <% if (enquiries && enquiries.length > 0) { %>
                        <% enquiries.forEach(enq => { %>
                            <div class="col-md-6 col-lg-4">
                                <div class="card border-0 shadow-sm rounded-4 h-100 <%= enq.status === 'Resolved' ? 'bg-light opacity-75' : '' %>">
                                    <div class="card-body p-4 d-flex flex-column">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <h5 class="fw-bold mb-0 text-capitalize"><i class="fas fa-user-circle text-muted me-2"></i><%= enq.name %></h5>
                                            <span class="badge <%= enq.status === 'Pending' ? 'bg-danger' : 'bg-success' %> rounded-pill"><%= enq.status %></span>
                                        </div>
                                        
                                        <p class="text-primary small mb-1 fw-bold"><i class="fas fa-envelope me-2"></i><%= enq.email %></p>
                                        <p class="text-muted small mb-3"><i class="fas fa-calendar-alt me-2"></i><%= new Date(enq.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                        
                                        <div class="bg-light p-3 rounded-3 mb-4 flex-grow-1">
                                            <h6 class="fw-bold text-dark small">Subject: <%= enq.subject || 'No Subject' %></h6>
                                            <p class="small text-secondary mb-0">"<%= enq.message %>"</p>
                                        </div>
                                        
                                        <div class="d-flex gap-2 mt-auto">
                                            <a href="mailto:<%= enq.email %>?subject=Reply from SMJ: <%= enq.subject %>" class="btn btn-sm btn-outline-primary fw-bold flex-grow-1">
                                                <i class="fas fa-reply me-1"></i> Reply
                                            </a>
                                            
                                            <form action="/admin/enquiries/<%= enq._id %>/status" method="POST" class="d-inline">
                                                <input type="hidden" name="status" value="<%= enq.status === 'Pending' ? 'Resolved' : 'Pending' %>">
                                                <button type="submit" class="btn btn-sm <%= enq.status === 'Pending' ? 'btn-success' : 'btn-secondary' %> fw-bold">
                                                    <i class="fas <%= enq.status === 'Pending' ? 'fa-check' : 'fa-undo' %>"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <i class="fas fa-inbox fa-3x text-muted mb-3 opacity-25"></i>
                            <h4 class="text-muted">Inbox is empty</h4>
                            <p class="small text-muted">No customer enquiries right now.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>